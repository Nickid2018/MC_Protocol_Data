[
    "container",
    [
        {
            "name": "chunkPosition",
            "type": [
                "reference",
                "chunk_pos"
            ]
        },
        {
            "name": "dimensionId",
            "type": "zigzag32"
        },
        {
            "name": "subChunksCount",
            "type": [
                "save",
                "varint",
                "subChunksCount"
            ]
        },
        {
            "name": "clientRequestSubChunkLimit",
            "type": [
                "switch",
                {
                    "compareTo": "subChunksCount",
                    "ranges": {
                        "~0": "void"
                    },
                    "default": "u16"
                }
            ]
        },
        {
            "name": "cachedEnabled",
            "type": [
                "save",
                "bool",
                "cachedEnabled"
            ]
        },
        {
            "name": "cacheBlobs",
            "type": [
                "switch",
                {
                    "compareTo": "cachedEnabled",
                    "fields": {
                        "true": [
                            "array",
                            {
                                "countType": "varint",
                                "type": "u64"
                            }
                        ],
                        "false": "void"
                    }
                }
            ]
        },
        {
            "name": "serializedChunkData",
            "type": "string"
        }
    ]
]